    "peekViewResult.matchHighlightBackground": "#e3e3d9",
    "peekViewResult.selectionBackground": "#fffff4",
    "peekViewResult.selectionForeground": "#111111",
    "quickInput.background": "#fffff4",
    "scrollbar.shadow": "#fffff400",
    "scrollbarSlider.activeBackground": "#1111112e",
    "scrollbarSlider.background": "#1111111e",
    "scrollbarSlider.hoverBackground": "#1111112e",
    "settings.checkboxBorder": "#ecece2",
    "settings.dropdownBorder": "#ecece2",
    "settings.modifiedItemIndicator": "#969690",
    "settings.textInputBorder": "#ecece2",
    "sideBar.background": "#fffff4",
    "sideBar.border": "#ecece2",
    "sideBar.foreground": "#4c4c49",
    "sideBarSectionHeader.background": "#fffff4",
    "sideBarSectionHeader.border": "#ecece2",
    "sideBarSectionHeader.foreground": "#111111",
    "sideBarTitle.foreground": "#111111",
    "statusBar.background": "#fffff4",
    "statusBar.border": "#ecece2",
    "statusBar.debuggingBackground": "#fffff4",
    "statusBar.debuggingBorder": "#ecece2",
    "statusBar.debuggingForeground": "#111111",
    "statusBar.foreground": "#111111",
    "statusBar.noFolderBackground": "#fffff4",
    "statusBar.noFolderBorder": "#ecece2",
    "statusBar.noFolderForeground": "#111111",
    "tab.activeBackground": "#fffff4",
    "tab.activeBorderTop": "#bd7c16",
    "tab.activeForeground": "#111111",
    "tab.border": "#fffff400",
    "tab.inactiveBackground": "#fffff4",
    "tab.inactiveForeground": "#8d8d87",
    "terminal.ansiBlack": "#fffff4",
    "terminal.ansiBlue": "#1E6FCC",
    "terminal.ansiBrightBlack": "#8d8d87",
    "terminal.ansiBrightBlue": "#1E6FCC",
    "terminal.ansiBrightCyan": "#41413e",
    "terminal.ansiBrightGreen": "#216609",
    "terminal.ansiBrightMagenta": "#7a3e9d",
    "terminal.ansiBrightRed": "#AA3731",
    "terminal.ansiBrightWhite": "#111111",
    "terminal.ansiBrightYellow": "#bd7c16",
    "terminal.ansiCyan": "#41413e",
    "terminal.ansiGreen": "#216609",
    "terminal.ansiMagenta": "#7a3e9d",
    "terminal.ansiRed": "#AA3731",
    "terminal.ansiWhite": "#111111",
    "terminal.ansiYellow": "#bd7c16",
    "terminal.background": "#fffff4",
    "terminal.foreground": "#111111",
    "terminalCursor.background": "#fffff4",
    "terminalCursor.foreground": "#111111",
    "textLink.activeForeground": "#1E6FCC",
    "textLink.foreground": "#1E6FCC",
    "titleBar.activeBackground": "#fffff4",
    "titleBar.activeForeground": "#111111",
    "titleBar.border": "#ecece2",
    "titleBar.inactiveBackground": "#fffff4",
    "titleBar.inactiveForeground": "#8d8d87",
    "tree.indentGuidesStroke": "#dadad0"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#aa642a"
      }
    },
    {
      "name": "String",
      "scope": ["string", "punctuation.definition.string", "constant.other.symbol", "entity.other.inherited-class"],
      "settings": {
        "foreground": "#216609"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#1E6FCC"
      }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#373735"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "entity.name", "support", "constant", "meta"],
      "settings": {
        "foreground": "#2e2e2d"
      }
    },
    {
      "name": "Function",
      "scope": ["entity.name.function", "support.function", "meta.require", "support.function.any-method"],
      "settings": {
        "foreground": "#4c4c49"
      }
    },
    {
      "name": "Punctuation",
      "scope": "punctuation",
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "name": "Constant Language",
      "scope": "constant.language",
      "settings": {
        "foreground": "#1E6FCC"
      }
    },
    {
      "name": "Class",
      "scope": ["support.class", "entity.name.class", "entity.name.type.class"],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "name": "Tag",
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#2e2e2d"
      }
    },
    {
      "name": "Attribute",
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid.deprecated", "invalid.illegal"],
      "settings": {
        "foreground": "#AA3731"
      }
    },
    {
      "name": "Markup Heading",
      "scope": ["markup.heading", "markup.heading punctuation.definition.heading", "entity.name.section"],
      "settings": {
        "foreground": "#4c4c49",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Bold",
      "scope": ["markup.bold", "punctuation.definition.bold"],
      "settings": {
        "foreground": "#111111",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Italic",
      "scope": ["markup.italic", "punctuation.definition.italic"],
      "settings": {
        "foreground": "#373735",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup Inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#216609"
      }
    },
    {
      "name": "Markup Deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#AA3731"
      }
    },
    {
      "name": "Markup Changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#bd7c16"
      }
    },
    {
      "name": "Markup Link",
      "scope": ["string.other.link", "meta.link"],
      "settings": {
        "foreground": "#1E6FCC"
      }
    },
    {
      "name": "Markup List",
      "scope": "markup.list",
      "settings": {
        "foreground": "#2e2e2d"
      }
    },
    {
      "name": "Markup Quote",
      "scope": "markup.quote",
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "name": "Markup Raw",
      "scope": "markup.raw.inline",
      "settings": {
        "foreground": "#111111"
      }
    }
  ]
}
